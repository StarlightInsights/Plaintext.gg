{
  "name": "plaintext-gg",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=25"
  },
  "browserslist": [
    "chrome >= 120",
    "firefox >= 120",
    "safari >= 17"
  ],
  "scripts": {
    "preinstall": "node -e \"if(!process.env.npm_execpath?.includes('pnpm')){console.error('Use pnpm, not npm.');process.exit(1)}\"",
    "postinstall": "playwright install chromium",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview --port 3999",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "pnpm exec playwright test",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check": "pnpm run typecheck && pnpm test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.2",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.5"
  }
}
