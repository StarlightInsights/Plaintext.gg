{
  "name": "plaintext-gg",
  "private": true,
  "type": "module",
  "scripts": {
    "preinstall": "node -e \"if(!process.env.npm_execpath?.includes('pnpm')){console.error('Use pnpm, not npm.');process.exit(1)}\"",
    "postinstall": "playwright install chromium",
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview --port 3999",
    "test": "vp run test:unit && vp run test:e2e",
    "test:unit": "vp test run",
    "test:e2e": "vp exec playwright test",
    "typecheck": "vp exec svelte-kit sync && vp exec svelte-check --tsconfig ./tsconfig.json",
    "check": "vp check && vp run typecheck && vp run test"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.8.0",
    "svelte": "^5.55.7",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "browserslist": [
    "chrome >= 120",
    "firefox >= 120",
    "safari >= 17"
  ],
  "engines": {
    "node": ">=26"
  },
  "packageManager": "pnpm@11.1.2"
}
